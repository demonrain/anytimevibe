# Local test environment (copy to .env.local — never commit secrets)
# Used by: pnpm dev:setup / pnpm dev:relay / pnpm dev:agent:local

NODE_ENV=development
PORT=8787
HOST=127.0.0.1

# Docker Compose dev Postgres (docker-compose.dev.yml)
POSTGRES_PASSWORD=anytimevibe_dev
DATABASE_URL=postgres://anytimevibe:anytimevibe_dev@127.0.0.1:5432/anytimevibe

# First-admin setup token (enter this in the web setup screen)
SETUP_TOKEN=local-dev-setup-token-change-me
COOKIE_SECRET=local-dev-cookie-secret-min-24-chars

# Browser origin for Vite dev server (must match the URL you open)
PUBLIC_ORIGIN=http://127.0.0.1:4173

REGISTRATION_ENABLED=true
MAX_USERS=50

# Optional local download links (empty is fine for local testing)
WINDOWS_CLIENT_URL=
MAC_CLIENT_URL=
UPDATE_FEED_URL=

# Web Push optional locally (leave empty to skip push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@localhost

# Desktop agent (local only): force relay URL + isolated user data
ANYTIMEVIBE_RELAY_URL=http://127.0.0.1:8787
