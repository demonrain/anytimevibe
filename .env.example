NODE_ENV=production
PORT=8787
DOMAIN=vibe.example.com
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgres://anytimevibe:change-me@postgres:5432/anytimevibe
SETUP_TOKEN=replace-with-a-long-random-token
COOKIE_SECRET=replace-with-a-long-random-secret
PUBLIC_ORIGIN=https://vibe.example.com
REGISTRATION_ENABLED=true
MAX_USERS=100
WINDOWS_CLIENT_URL=https://github.com/demonrain/anytimevibe/releases/latest/download/AnytimeVibe-Agent-Setup.exe
# Leave empty until a real macOS build is published; web UI shows「敬请期待」.
MAC_CLIENT_URL=
UPDATE_FEED_URL=https://github.com/demonrain/anytimevibe/releases/latest/download
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
