{
  "name": "anytimevibe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "dev:setup": "node scripts/dev-setup.mjs",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "dev:db:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:stack": "node scripts/dev-stack.mjs",
    "dev:relay": "node scripts/run-with-env.mjs .env.local -- pnpm --filter @anytimevibe/relay dev",
    "dev:web": "pnpm --filter @anytimevibe/web dev",
    "dev:agent": "pnpm --filter @anytimevibe/agent dev",
    "dev:agent:local": "node scripts/run-with-env.mjs .env.local -- pnpm --filter @anytimevibe/agent dev:local"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
