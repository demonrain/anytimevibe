{
  "name": "anytimevibe",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "pnpm -r --sort build",
    "typecheck": "pnpm -r --sort typecheck",
    "test": "vitest run",
    "dev:relay": "pnpm --filter @anytimevibe/relay dev",
    "dev:web": "pnpm --filter @anytimevibe/web dev",
    "dev:agent": "pnpm --filter @anytimevibe/agent dev"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
