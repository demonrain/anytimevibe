{
  "name": "@anytimevibe/agent",
  "version": "0.4.5",
  "description": "Windows and macOS bridge for encrypted remote Codex sessions",
  "author": "AnytimeVibe",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm build && electron .",
    "build": "tsup src/main.ts src/preload.ts --format cjs --platform node --external electron --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:dir": "pnpm build && electron-builder --win --dir",
    "package:win": "pnpm build && electron-builder --win nsis",
    "package:mac": "pnpm build && electron-builder --mac dmg zip --universal"
  },
  "dependencies": {
    "@anytimevibe/protocol": "workspace:*",
    "electron-updater": "6.6.2",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "electron": "^36.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.anytimevibe.agent",
    "productName": "AnytimeVibe Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "artifactName": "AnytimeVibe-Agent-Setup.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "AnytimeVibe-Agent.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "publish": [
      { "provider": "generic", "url": "https://updates.anytimevibe.invalid" }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
