{
  "name": "@anytimevibe/agent",
  "version": "0.4.27",
  "description": "随码桌面代理：在 Windows / macOS 上安全接力远程 Codex 任务",
  "author": "随码",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "dev": "pnpm build && electron .",
    "dev:local": "pnpm build && electron . --user-data-dir=../../.local/agent-data",
    "build:protocol": "pnpm -C ../../packages/protocol run build",
    "build": "pnpm run build:protocol && tsup && node ../../scripts/check-agent-requires.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package:dir": "pnpm build && electron-builder --win --dir",
    "package:win": "pnpm build && electron-builder --win nsis",
    "package:mac": "pnpm build && electron-builder --mac dmg zip --universal"
  },
  "dependencies": {},
  "devDependencies": {
    "@anytimevibe/protocol": "workspace:*",
    "@types/ws": "^8.18.1",
    "electron": "^36.5.0",
    "electron-builder": "^26.0.12",
    "electron-updater": "6.6.2",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "build": {
    "appId": "com.anytimevibe.agent",
    "productName": "随码",
    "executableName": "AnytimeVibe-Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "AnytimeVibe-Agent-Setup.${ext}",
      "signAndEditExecutable": true,
      "signExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "artifactName": "AnytimeVibe-Agent.${ext}",
      "category": "public.app-category.developer-tools"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.anytimevibe.invalid"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "随码",
      "uninstallDisplayName": "随码",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
